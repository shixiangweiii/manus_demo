# === LLM API Configuration ===
# For DeepSeek:
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-
LLM_MODEL=deepseek-v4-flash

# For 千问
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=sk-
# LLM_MODEL=qwen3.6-plus

# For Ollama (local):
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3

# For Qwen (DashScope):
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=your-api-key-here
# LLM_MODEL=qwen-turbo

# === Agent Limits ===
MAX_CONTEXT_TOKENS=8000
MAX_REACT_ITERATIONS=10
MAX_REPLAN_ATTEMPTS=3

# === DAG Execution ===
MAX_PARALLEL_NODES=3

# === Memory ===
MEMORY_DIR=~/.manus_demo
SHORT_TERM_WINDOW=20

# === Tools ===
SANDBOX_DIR=~/.manus_demo/sandbox
CODE_EXEC_TIMEOUT=30

# === Tracing (v7) ===
# TRACING_ENABLED=true
# TRACING_BACKEND=console          # console / file / rich / otlp / phoenix
# TRACING_ENDPOINT=http://localhost:4318
# TRACING_SERVICE_NAME=manus-demo
# TRACING_SAMPLE_RATE=1.0
# TRACING_LOG_PROMPTS=false
# TRACING_MAX_ATTR_LENGTH=1000

TRACING_ENABLED=true
TRACING_BACKEND=file
TRACING_LOG_PROMPTS=true
TRACING_SAMPLE_RATE=1.0

# auto
# simple
# complex
# emergent
# PLAN_MODE=complex
# 不启用 v8/v5
# EMERGENT_PLANNING_ENABLED=false
# v8 目标驱动
# ENABLE_GOAL_DRIVEN_PLANNER=true
# v5
# ENABLE_GOAL_DRIVEN_PLANNER=false
