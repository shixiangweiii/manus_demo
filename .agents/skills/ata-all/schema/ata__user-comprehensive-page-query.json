{
  "version": 1,
  "id": "ata::user-comprehensive-page-query",
  "description": "根据花名、姓名、工号等特征查询该用户对应的 ATA 用户id 。 ATA 用户id一般是11或12开头的11位数字，用于接口需要 userId 的入参。工号为字符串，可含字母或数字，多数为数字。花名、姓名一般是2-3个中文也可能是英文。",
  "javaMethod": "com.alibaba.atasuper.client.v2.user.DomainUserClientService#comprehensivePageQuery",
  "inputSchema": {
    "description": "根据花名、姓名、工号等特征查询该用户对应的 ATA 用户id 。 ATA 用户id一般是11或12开头的11位数字，用于接口需要 userId 的入参。",
    "properties": {
      "fieldName_0": {
        "description": "用户搜索的参数",
        "properties": {
          "pageSize": {
            "description": "分页大小，建议3就够了，查询很精确",
            "type": "number"
          },
          "searchKey": {
            "description": "需要查询用户的特征信息，一般是花名、姓名、工号。工号为字符串，可含字母或数字，多数为数字。花名、姓名一般是2-3个中文也可能是英文。",
            "type": "string"
          }
        },
        "required": [
          "pageSize",
          "searchKey"
        ],
        "type": "object"
      },
      "fieldName_1": {
        "description": "返回字段的选择器，可以返回一些额外字段，在选择器中没有的字段默认这个接口都会直接返回的，在用户没有特别说明的情况下选择器建议不传任何字段",
        "type": "object"
      }
    },
    "required": [
      "fieldName_0"
    ],
    "type": "object"
  },
  "outputSchema": {
    "description": "AtaPageResult<DomainUserClientDTO> 用户分页结果",
    "type": "object",
    "properties": {
      "success": {
        "type": "boolean",
        "description": "是否成功"
      },
      "errorCode": {
        "type": "string",
        "description": "错误编码"
      },
      "errorMsg": {
        "type": "string",
        "description": "错误信息"
      },
      "traceId": {
        "type": "string",
        "description": "追踪id"
      },
      "content": {
        "type": "object",
        "description": "分页数据",
        "properties": {
          "data": {
            "type": "array",
            "description": "用户列表",
            "items": {
              "$ref": "#/$defs/DomainUserClientDTO"
            }
          },
          "totalCount": {
            "type": "number",
            "description": "总条数"
          },
          "currentPage": {
            "type": "number",
            "description": "当前页码"
          },
          "pageSize": {
            "type": "number",
            "description": "分页大小"
          }
        }
      }
    },
    "$defs": {
      "DomainUserClientDTO": {
        "type": "object",
        "description": "用户信息",
        "properties": {
          "id": {
            "type": "number",
            "description": "用户id"
          },
          "workId": {
            "type": "string",
            "description": "用户工号"
          },
          "realname": {
            "type": "string",
            "description": "真实姓名"
          },
          "nickname": {
            "type": "string",
            "description": "花名"
          },
          "deptNo": {
            "type": "string",
            "description": "员工部门编号"
          },
          "showDepartment": {
            "type": "string",
            "description": "部门名称，用于前端展示"
          }
        },
        "required": [
          "id",
          "workId",
          "realname",
          "nickname",
          "deptNo"
        ]
      }
    }
  }
}
