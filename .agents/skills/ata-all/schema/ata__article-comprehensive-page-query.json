{
  "version": 1,
  "id": "ata::article-comprehensive-page-query",
  "description": "根据关键字、文章类型、知识体系标签、用户工号、创建时间等信息来搜索文章信息。并且可以按每周、每月、每日的访问量，互动量等字段来排序文章内容。",
  "javaMethod": "com.alibaba.atasuper.client.v2.article.ArticleClientService#comprehensivePageQuery",
  "inputSchema": {
    "description": "根据关键字、文章类型、知识体系标签、用户工号、创建时间等信息来搜索文章信息。并且可以按每周、每月、每日的访问量，互动量等字段来排序文章内容。",
    "properties": {
      "fieldName_0": {
        "description": "内容搜索的参数",
        "properties": {
          "ataCategoryContentId": {
            "description": "知识体系标签id，`category-list-all`接口可以获取",
            "type": "number"
          },
          "ataCategoryContentIdList": {
            "description": "知识体系标签id，`category-list-all`接口可以获取",
            "items": {
              "description": "知识体系标签id，`category-list-all`接口可以获取",
              "type": "number"
            },
            "type": "array"
          },
          "contentTypeId": {
            "description": "文章类型标签id",
            "type": "number"
          },
          "createTimeShadowGe": {
            "description": "文章创建日期大于等于,格式 yyyy-MM-dd HH:mm:ss",
            "type": "string"
          },
          "createTimeShadowLt": {
            "description": "文章创建日期小于,格式 yyyy-MM-dd HH:mm:ss",
            "type": "string"
          },
          "currentPage": {
            "description": "当前页码",
            "type": "number"
          },
          "enableReturnCount": {
            "description": "是否返回总条数",
            "type": "boolean"
          },
          "orderByList": {
            "description": "排序的字段信息",
            "items": {
              "description": "排序的字段信息",
              "properties": {
                "direction": {
                  "description": "排序 ASC:顺序 DESC:倒序",
                  "enum": [
                    "ASC",
                    "DESC"
                  ],
                  "type": "string"
                },
                "orderConditionName": {
                  "description": "排序字段名 创建时间：create_time_shadow 访问次数：hitcount 30天访问次数：hitcount_30d 7天访问次数：hitcount_7d 7天互动数：action_count_7d 1天访问次数：hitcount_1d 1天互动数：action_count_1d",
                  "type": "string"
                }
              },
              "required": [
                "orderConditionName",
                "direction"
              ],
              "type": "object"
            },
            "type": "array"
          },
          "pageSize": {
            "description": "分页大小",
            "type": "number"
          },
          "searchKey": {
            "description": "搜索内容的关键字",
            "type": "string"
          },
          "userId": {
            "description": "ATA用户id,一般是11或12开头的11位数字。`user-comprehensive-page-query`可以把花名、姓名、工号转成用户id",
            "type": "number"
          },
          "userIdList": {
            "description": "ATA用户id,一般是11或12开头的11位数字。,`user-comprehensive-page-query`可以把花名、姓名、工号转成用户id",
            "items": {
              "description": "ATA用户id,一般是11或12开头的11位数字。`user-comprehensive-page-query`可以把花名、姓名、工号转成用户id",
              "type": "number"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "fieldName_1": {
        "description": "返回字段的选择器，可以返回一些额外字段，在选择器中没有的字段默认这个接口都会直接返回的，在用户没有特别说明的情况下选择器建议不传任何字段",
        "properties": {
          "articleRecommendList": {
            "description": "翰林院推荐的列表",
            "type": "boolean"
          },
          "articleRecommendListSelector": {
            "description": "选择articleRecommendList对象里面的字段",
            "properties": {
              "user": {
                "description": "用户详细信息",
                "type": "boolean"
              }
            },
            "type": "object"
          },
          "content": {
            "description": "文章的详细内容信息，用户没有说明的情况下建议传false,每日超过查询次数会被限流",
            "type": "boolean"
          },
          "recommendCount": {
            "description": "被翰林院推荐的次数",
            "type": "boolean"
          },
          "user": {
            "description": "用户详细信息",
            "type": "boolean"
          }
        },
        "type": "object"
      }
    },
    "required": [
      "fieldName_0"
    ],
    "type": "object"
  },
  "outputSchema": {
    "description": "AtaPageResult<ArticleClientDTO> 文章分页结果",
    "type": "object",
    "properties": {
      "success": {
        "type": "boolean",
        "description": "是否成功"
      },
      "errorCode": {
        "type": "string",
        "description": "错误编码"
      },
      "errorMsg": {
        "type": "string",
        "description": "错误信息"
      },
      "traceId": {
        "type": "string",
        "description": "追踪id"
      },
      "content": {
        "type": "object",
        "description": "分页数据",
        "properties": {
          "data": {
            "type": "array",
            "description": "文章列表",
            "items": {
              "$ref": "#/$defs/ArticleClientDTO"
            }
          },
          "totalCount": {
            "type": "number",
            "description": "总条数（需要 enableReturnCount=true 才会返回）"
          },
          "currentPage": {
            "type": "number",
            "description": "当前页码"
          },
          "pageSize": {
            "type": "number",
            "description": "分页大小"
          }
        }
      }
    },
    "$defs": {
      "ArticleClientDTO": {
        "type": "object",
        "description": "文章信息",
        "properties": {
          "articleId": {
            "type": "number",
            "description": "文章id"
          },
          "articleTitle": {
            "type": "string",
            "description": "文章标题"
          },
          "hitcount": {
            "type": "number",
            "description": "浏览量"
          },
          "comcount": {
            "type": "number",
            "description": "评论数"
          },
          "goodcount": {
            "type": "number",
            "description": "点赞数"
          },
          "markcount": {
            "type": "number",
            "description": "收藏数"
          },
          "recommendCount": {
            "type": "number",
            "description": "翰林院推荐次数（需通过selector开启）"
          },
          "articleRecommendList": {
            "type": "array",
            "description": "翰林院推荐列表（需通过selector开启）",
            "items": {
              "$ref": "#/$defs/ArticleRecommendClientDTO"
            }
          },
          "sharecount": {
            "type": "number",
            "description": "分享数"
          },
          "userId": {
            "type": "number",
            "description": "作者id"
          },
          "user": {
            "$ref": "#/$defs/DomainUserClientDTO",
            "description": "作者信息（需通过selector开启）"
          },
          "articleAbstract": {
            "type": "string",
            "description": "文章简介"
          },
          "articleImg": {
            "type": "string",
            "description": "封面图片"
          },
          "url": {
            "type": "string",
            "description": "文章链接"
          },
          "modifyTime": {
            "type": "string",
            "description": "更新时间"
          },
          "createTimeShadow": {
            "type": "string",
            "description": "文章最原始的创建时间"
          },
          "pureContent": {
            "type": "string",
            "description": "纯净的文本内容（需通过selector content=true开启，每日查询超限会被限流）"
          },
          "permission": {
            "type": "string",
            "description": "文章权限：PUBLIC 公开 / PRIVATE 私有"
          }
        },
        "required": [
          "articleId",
          "articleTitle",
          "hitcount",
          "comcount",
          "goodcount",
          "markcount",
          "userId",
          "url"
        ]
      },
      "ArticleRecommendClientDTO": {
        "type": "object",
        "description": "翰林院推荐记录",
        "properties": {
          "articleId": {
            "type": "number",
            "description": "推荐的文章ID"
          },
          "userId": {
            "type": "number",
            "description": "推荐人用户id"
          },
          "user": {
            "$ref": "#/$defs/DomainUserClientDTO",
            "description": "推荐人信息（需通过selector开启）"
          }
        },
        "required": [
          "articleId",
          "userId"
        ]
      },
      "DomainUserClientDTO": {
        "type": "object",
        "description": "用户信息",
        "properties": {
          "id": {
            "type": "number",
            "description": "用户id"
          },
          "workId": {
            "type": "string",
            "description": "用户工号"
          },
          "realname": {
            "type": "string",
            "description": "真实姓名"
          },
          "nickname": {
            "type": "string",
            "description": "花名"
          },
          "deptNo": {
            "type": "string",
            "description": "员工部门编号"
          },
          "showDepartment": {
            "type": "string",
            "description": "部门名称，用于前端展示"
          }
        },
        "required": [
          "id",
          "workId",
          "realname",
          "nickname",
          "deptNo"
        ]
      }
    }
  }
}
