{
  "version": 1,
  "id": "ata::article-article-recommend",
  "description": "查询翰林院推荐的热门文章。翰林院是 ATA 内部的组织，翰林院由具备技术鉴赏力、影响力的技术专家组成。他们挖掘技术好文、推动内容输出、引领社区技术创新、促进技术交流实践。他们来自不同的组织，能从不同业务、技术领域视角提出技术建议和反馈，让多元化的优秀技术内容被更多的看见！",
  "javaMethod": "com.alibaba.atasuper.client.v2.article.ArticleClientService#articleRecommend",
  "inputSchema": {
    "description": "查询翰林院推荐的热门文章。翰林院是 ATA 内部的组织，翰林院由具备技术鉴赏力、影响力的技术专家组成。他们挖掘技术好文、推动内容输出、引领社区技术创新、促进技术交流实践。他们来自不同的组织，能从不同业务、技术领域视角提出技术建议和反馈，让多元化的优秀技术内容被更多的看见！",
    "properties": {
      "fieldName_0": {
        "description": "推荐热门文章的参数，前面没有参数",
        "properties": {},
        "required": [],
        "type": "object"
      },
      "fieldName_1": {
        "description": "返回字段的选择器，可以返回一些额外字段，在选择器中没有的字段默认这个接口都会直接返回的，在用户没有特别说明的情况下选择器建议不传任何字段",
        "properties": {
          "articleRecommendList": {
            "description": "翰林院推荐的列表",
            "type": "boolean"
          },
          "articleRecommendListSelector": {
            "description": "选择articleRecommendList对象里面的字段",
            "properties": {
              "user": {
                "description": "用户详细信息",
                "type": "boolean"
              }
            },
            "type": "object"
          },
          "content": {
            "description": "文章的详细内容信息，用户没有说明的情况下建议传false,每日超过查询次数会被限流",
            "type": "boolean"
          },
          "recommendCount": {
            "description": "被翰林院推荐的次数",
            "type": "boolean"
          },
          "user": {
            "description": "用户详细信息",
            "type": "boolean"
          }
        },
        "type": "object"
      }
    },
    "required": [
      "fieldName_0"
    ],
    "type": "object"
  },
  "outputSchema": {
    "description": "AtaListResult<ArticleClientDTO> 文章列表结果",
    "type": "object",
    "properties": {
      "success": {
        "type": "boolean",
        "description": "是否成功"
      },
      "errorCode": {
        "type": "string",
        "description": "错误编码"
      },
      "errorMsg": {
        "type": "string",
        "description": "错误信息"
      },
      "traceId": {
        "type": "string",
        "description": "追踪id"
      },
      "content": {
        "type": "array",
        "description": "文章列表",
        "items": {
          "$ref": "#/$defs/ArticleClientDTO"
        }
      }
    },
    "$defs": {
      "ArticleClientDTO": {
        "type": "object",
        "description": "文章信息",
        "properties": {
          "articleId": {
            "type": "number",
            "description": "文章id"
          },
          "articleTitle": {
            "type": "string",
            "description": "文章标题"
          },
          "hitcount": {
            "type": "number",
            "description": "浏览量"
          },
          "comcount": {
            "type": "number",
            "description": "评论数"
          },
          "goodcount": {
            "type": "number",
            "description": "点赞数"
          },
          "markcount": {
            "type": "number",
            "description": "收藏数"
          },
          "recommendCount": {
            "type": "number",
            "description": "翰林院推荐次数（需通过selector开启）"
          },
          "articleRecommendList": {
            "type": "array",
            "description": "翰林院推荐列表（需通过selector开启）",
            "items": {
              "$ref": "#/$defs/ArticleRecommendClientDTO"
            }
          },
          "sharecount": {
            "type": "number",
            "description": "分享数"
          },
          "userId": {
            "type": "number",
            "description": "作者id"
          },
          "user": {
            "$ref": "#/$defs/DomainUserClientDTO",
            "description": "作者信息（需通过selector开启）"
          },
          "articleAbstract": {
            "type": "string",
            "description": "文章简介"
          },
          "articleImg": {
            "type": "string",
            "description": "封面图片"
          },
          "url": {
            "type": "string",
            "description": "文章链接"
          },
          "modifyTime": {
            "type": "string",
            "description": "更新时间"
          },
          "createTimeShadow": {
            "type": "string",
            "description": "文章最原始的创建时间"
          },
          "pureContent": {
            "type": "string",
            "description": "纯净的文本内容（需通过selector content=true开启，每日查询超限会被限流）"
          },
          "permission": {
            "type": "string",
            "description": "文章权限：PUBLIC 公开 / PRIVATE 私有"
          }
        },
        "required": [
          "articleId",
          "articleTitle",
          "hitcount",
          "comcount",
          "goodcount",
          "markcount",
          "userId",
          "url"
        ]
      },
      "ArticleRecommendClientDTO": {
        "type": "object",
        "description": "翰林院推荐记录",
        "properties": {
          "articleId": {
            "type": "number",
            "description": "推荐的文章ID"
          },
          "userId": {
            "type": "number",
            "description": "推荐人用户id"
          },
          "user": {
            "$ref": "#/$defs/DomainUserClientDTO",
            "description": "推荐人信息（需通过selector开启）"
          }
        },
        "required": [
          "articleId",
          "userId"
        ]
      },
      "DomainUserClientDTO": {
        "type": "object",
        "description": "用户信息",
        "properties": {
          "id": {
            "type": "number",
            "description": "用户id"
          },
          "workId": {
            "type": "string",
            "description": "用户工号"
          },
          "realname": {
            "type": "string",
            "description": "真实姓名"
          },
          "nickname": {
            "type": "string",
            "description": "花名"
          },
          "deptNo": {
            "type": "string",
            "description": "员工部门编号"
          },
          "showDepartment": {
            "type": "string",
            "description": "部门名称，用于前端展示"
          }
        },
        "required": [
          "id",
          "workId",
          "realname",
          "nickname",
          "deptNo"
        ]
      }
    }
  }
}
