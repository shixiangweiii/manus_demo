# === LLM API Configuration ===
# For DeepSeek:
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=deepseek-chat

# For Ollama (local):
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3

# For Qwen (DashScope):
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=your-api-key-here
# LLM_MODEL=qwen-turbo

# === Agent Limits ===
MAX_CONTEXT_TOKENS=16000
MAX_REACT_ITERATIONS=10
MAX_REPLAN_ATTEMPTS=3

# === DAG Execution ===
MAX_PARALLEL_NODES=3

# === Memory ===
MEMORY_DIR=~/.manus_demo
SHORT_TERM_WINDOW=20

# === Tools ===
SANDBOX_DIR=~/.manus_demo/sandbox
CODE_EXEC_TIMEOUT=30

# === User Location Resolution ===
# 按优先级降级解析：env var > {MEMORY_DIR}/user_location.md > IP 接口（ipapi.co 主 + ip.sb 备）
# USER_LOCATION=杭州
# LOCATION_IP_LOOKUP_ENABLED=true    # 是否允许调用公网 IP 接口推断位置（默认 true；隐私敏感场景可设 false 关闭）

# === Web Search (v10) ===
# DuckDuckGo 搜索，无需 API Key。如遇限速可调高超时或减少 max_results。
# WEB_SEARCH_MAX_RESULTS=5
# WEB_SEARCH_TIMEOUT=15

# === Bailian MCP (Aliyun Search & WebParser, v11) ===
# 百炼 MCP 搜索（优先使用；为空时回退到 DuckDuckGo）
# DASHSCOPE_API_KEY=sk-xxxx
# BAILIAN_WEBSEARCH_MCP_URL=https://dashscope.aliyuncs.com/api/v1/mcps/WebSearch/mcp
# BAILIAN_WEBPARSER_MCP_URL=https://dashscope.aliyuncs.com/api/v1/mcps/WebParser/mcp

# === Convergence Guidance ===
# SEARCH_CONVERGENCE_THRESHOLD=3
# FETCH_URL_MAX_CONTENT_LENGTH=10000

# === Tracing (v7) ===
# TRACING_ENABLED=true
# TRACING_BACKEND=console          # console / file / rich / otlp / phoenix
# TRACING_ENDPOINT=http://localhost:4318
# TRACING_SERVICE_NAME=manus-demo
# TRACING_SAMPLE_RATE=1.0
# TRACING_LOG_PROMPTS=false
# TRACING_MAX_ATTR_LENGTH=1000

# === v9.0 SubAgent (Claude Code Subagent pattern, default OFF) ===
# 子智能体（depth=1，独立上下文，仅返回结构化摘要）
# SUBAGENT_ENABLED=false                  # 总开关（默认关闭，向后兼容）
# SUBAGENT_MAX_ITERATIONS=10              # 内部 ReAct 最大迭代次数
# SUBAGENT_TIMEOUT=300                    # 执行超时时间（秒）
# SUBAGENT_MAX_CONCURRENT=3               # 最大并发 SubAgent 数量（Semaphore 限流）
# SUBAGENT_SUMMARY_MAX_LENGTH=2000        # 摘要最大字符数
# SUBAGENT_MAX_CALLS_PER_TASK=3           # 单任务调用次数上限（反模式 #3/#8 防御）
# SUBAGENT_MAX_TOKENS_PER_CALL=50000      # 单次调用 Token 预算上限（反模式 #8 防御）
# SUBAGENT_DEFAULT_TOOL_WHITELIST=        # 默认工具白名单（逗号分隔，空=全量授权）
